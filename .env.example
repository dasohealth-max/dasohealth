# Database
# Use Supabase pooler URLs for local development. Do not commit real credentials.
DATABASE_URL="postgresql://postgres.example:REPLACE_WITH_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.example:REPLACE_WITH_PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"
DATABASE_SSL_REJECT_UNAUTHORIZED="false"

# Supabase browser/client configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase privileged server-only key
# Never expose this value to client components, logs, screenshots, or committed files.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cron route protection
CRON_SECRET="replace-with-a-long-random-cron-secret"

# Optional Playwright E2E test accounts
E2E_SUPER_EMAIL="super@example.test"
E2E_PM_EMAIL="project-manager@example.test"
E2E_CLERK_EMAIL="clerk@example.test"
E2E_SCREENER_EMAIL="screener@example.test"
E2E_PASSWORD="replace-with-local-test-password"
