generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  SuperAdministrator     @map("Super Administrator")
  ProjectManager         @map("Project Manager")
  DataClerk              @map("Data Clerk")
  ScreeningOfficer       @map("Screening Officer")
  // Legacy roles preserved for existing database records
  CampaignManager        @map("Campaign Manager")
  HospitalCoordinator    @map("Hospital Coordinator")
  Ophthalmologist
  Surgeon
  FollowUpOfficer        @map("Follow-Up Officer")
  OutreachOfficer        @map("Outreach Officer")
  LogisticsOfficer       @map("Logistics Officer")
  InventoryOfficer       @map("Inventory Officer")
  MEALOfficer            @map("MEAL Officer")
  FinanceOfficer         @map("Finance Officer")
  DonorUser              @map("Donor User")

  @@map("user_role")
}

enum CampaignType {
  Cataract
  SchoolEyeHealth     @map("School Eye Health")
  DiabeticRetinopathy @map("Diabetic Retinopathy")
  Glaucoma
  General
  CataractSurgeryOutreach @map("Cataract Surgery Outreach")
  EyeVisionOutreach       @map("Eye Vision Outreach")
  GeneralEyeScreening     @map("General Eye Screening")
  MixedOutreach           @map("Mixed Outreach")

  @@map("campaign_type")
}

enum CampaignStatus {
  Planned
  Active
  Completed
  Suspended

  @@map("campaign_status")
}

enum RegionalPlanStatus {
  OnTrack @map("On Track")
  Behind
  Completed
  Suspended

  @@map("regional_plan_status")
}

enum Sex {
  Male
  Female
  Other

  @@map("sex")
}

enum DisabilityStatus {
  None
  Visual
  Hearing
  Mobility
  Cognitive
  Multiple

  @@map("disability_status")
}

enum VaGrade {
  V6_6   @map("6/6")
  V6_9   @map("6/9")
  V6_12  @map("6/12")
  V6_18  @map("6/18")
  V6_24  @map("6/24")
  V6_36  @map("6/36")
  V6_60  @map("6/60")
  LT6_60 @map("<6/60")
  CF
  HM
  PL
  NPL

  @@map("va_grade")
}

enum ScreeningRecommendation {
  Discharge
  ReferForSurgery      @map("Refer for Surgery")
  FurtherInvestigation @map("Further Investigation")
  Glasses
  FollowUp             @map("Follow-up")
  Positive

  @@map("screening_recommendation")
}

enum SurgeryEye {
  Right
  Left
  Both

  @@map("surgery_eye")
}

enum LensType {
  PMMA
  FoldableAcrylic @map("Foldable Acrylic")
  Hydrophilic
  Hydrophobic

  @@map("lens_type")
}

enum SurgeryStatus {
  Scheduled
  Completed
  Cancelled
  Postponed

  @@map("surgery_status")
}

enum FollowUpMilestone {
  Day1    @map("Day 1")
  Week1   @map("Week 1")
  Month1  @map("Month 1")

  @@map("follow_up_milestone")
}

enum FollowUpStatus {
  Pending
  Due
  Overdue
  Completed
  Missed

  @@map("follow_up_status")
}

enum DoctorReviewStatus {
  NotNeeded  @map("Not Needed")
  Pending
  Completed

  @@map("doctor_review_status")
}

enum MedicationStatus {
  Prescribed
  Taking
  Completed
  Stopped

  @@map("medication_status")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  email          String   @unique
  role           UserRole
  assignedRegion String?  @map("assigned_region")
  initials       String
  color          String   @default("#0d9488")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("users")
}

model Campaign {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  type              CampaignType
  status            CampaignStatus @default(Planned)
  region            String         @default("Banadir / Mogadishu")
  operationDistrict String         @default("Mogadishu") @map("operation_district")
  projectManagerId  String         @default("") @map("project_manager_id")
  projectManagerName String        @default("") @map("project_manager_name")
  startDate         DateTime       @map("start_date") @db.Date
  endDate           DateTime       @map("end_date") @db.Date
  budget            Decimal        @default(0) @map("budget") @db.Decimal(14, 2)
  donors            String         @default("")
  targetScreenings  Int            @default(0) @map("target_screenings")
  targetSurgeries   Int            @default(0) @map("target_surgeries")
  targetFollowUps   Int            @default(0) @map("target_follow_ups")
  description       String         @default("")
  notes             String         @default("")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)

  regions    CampaignRegion[]
  patients   Patient[]
  screenings Screening[]
  surgeries  Surgery[]
  followUps  FollowUp[]

  @@index([region], map: "idx_campaigns_region")
  @@index([region, status], map: "idx_campaigns_region_status")
  @@index([projectManagerId], map: "idx_campaigns_project_manager_id")
  @@index([createdAt(sort: Desc)], map: "idx_campaigns_created_at")
  @@map("campaigns")
}

model CampaignRegion {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String             @map("campaign_id") @db.Uuid
  type                CampaignType       @default(MixedOutreach)
  region              String
  operationDistrict   String             @map("operation_district")
  regionalManagerId   String             @default("") @map("regional_manager_id")
  regionalManagerName String             @default("") @map("regional_manager_name")
  targetPatients      Int                @default(0) @map("target_patients")
  targetScreenings    Int                @default(0) @map("target_screenings")
  targetSurgeries     Int                @default(0) @map("target_surgeries")
  startDate           DateTime           @map("start_date") @db.Date
  endDate             DateTime           @map("end_date") @db.Date
  status              RegionalPlanStatus @default(OnTrack)
  notes               String             @default("")
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)

  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  patients   Patient[]
  screenings Screening[]
  surgeries  Surgery[]
  followUps  FollowUp[]

  @@unique([campaignId, region, type], map: "campaign_regions_campaign_id_region_type_key")
  @@index([campaignId], map: "idx_campaign_regions_campaign_id")
  @@index([region], map: "idx_campaign_regions_region")
  @@index([type], map: "idx_campaign_regions_type")
  @@index([status], map: "idx_campaign_regions_status")
  @@map("campaign_regions")
}

model Patient {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientCode       String           @unique @map("patient_code")
  fullName          String           @map("full_name")
  dateOfBirth       DateTime         @map("date_of_birth") @db.Date
  sex               Sex
  phone             String
  email             String?
  district          String
  region            String
  operationDistrict String           @default("") @map("operation_district")
  occupation        String?
  education         String?
  disabilityStatus  DisabilityStatus @default(None) @map("disability_status")
  insuranceStatus   String           @default("None") @map("insurance_status")
  emergencyContact  String           @default("") @map("emergency_contact")
  emergencyPhone    String           @default("") @map("emergency_phone")
  consentGiven      Boolean          @default(false) @map("consent_given")
  consentDate       DateTime?        @map("consent_date") @db.Date
  campaignId        String?          @map("campaign_id") @db.Uuid
  campaignRegionId  String?          @map("campaign_region_id") @db.Uuid
  referralSource    String           @default("") @map("referral_source")
  notes             String?
  registeredById    String           @default("") @map("registered_by_id")
  registeredByName  String           @default("") @map("registered_by_name")
  screeningStatus   String           @default("Awaiting Screening") @map("screening_status")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  campaignRegion CampaignRegion? @relation(fields: [campaignRegionId], references: [id])
  screenings     Screening[]
  surgeries      Surgery[]
  followUps      FollowUp[]

  @@index([campaignId], map: "idx_patients_campaign_id")
  @@index([campaignRegionId], map: "idx_patients_campaign_region_id")
  @@index([patientCode], map: "idx_patients_patient_code")
  @@index([region], map: "idx_patients_region")
  @@index([screeningStatus], map: "idx_patients_screening_status")
  @@index([region, screeningStatus], map: "idx_patients_region_screening_status")
  @@index([createdAt(sort: Desc)], map: "idx_patients_created_at")
  @@index([fullName, phone, campaignId], map: "idx_patients_duplicate_guard")
  @@map("patients")
}

model Screening {
  id                  String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId           String                  @map("patient_id") @db.Uuid
  patientName         String                  @map("patient_name")
  campaignId          String                  @map("campaign_id") @db.Uuid
  campaignRegionId    String?                 @map("campaign_region_id") @db.Uuid
  region              String                  @default("Banadir / Mogadishu")
  operationDistrict   String                  @default("Mogadishu") @map("operation_district")
  screenedBy          String                  @map("screened_by")
  screenedById        String                  @default("") @map("screened_by_id")
  screenedByName      String                  @default("") @map("screened_by_name")
  screenedAt          DateTime                @map("screened_at") @db.Timestamptz(3)
  vaRightUnaided      VaGrade                 @map("va_right_unaided")
  vaLeftUnaided       VaGrade                 @map("va_left_unaided")
  vaRightCorrected    VaGrade?                @map("va_right_corrected")
  vaLeftCorrected     VaGrade?                @map("va_left_corrected")
  iopRight            Int?                    @map("iop_right") @db.SmallInt
  iopLeft             Int?                    @map("iop_left") @db.SmallInt
  cataractSuspected   Boolean                 @default(false) @map("cataract_suspected")
  glaucomaSuspected   Boolean                 @default(false) @map("glaucoma_suspected")
  diabeticRetinopathy Boolean                 @default(false) @map("diabetic_retinopathy")
  otherFindings       String                  @default("") @map("other_findings")
  medicalHistory      String                  @default("") @map("medical_history")
  currentMedications  String                  @default("") @map("current_medications")
  recommendation      ScreeningRecommendation
  notes               String                  @default("")
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(3)

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  campaign       Campaign        @relation(fields: [campaignId], references: [id])
  campaignRegion CampaignRegion? @relation(fields: [campaignRegionId], references: [id])

  @@index([patientId], map: "idx_screenings_patient_id")
  @@index([campaignId], map: "idx_screenings_campaign_id")
  @@index([campaignRegionId], map: "idx_screenings_campaign_region_id")
  @@index([region], map: "idx_screenings_region")
  @@index([region, campaignId], map: "idx_screenings_region_campaign_id")
  @@index([screenedAt(sort: Desc)], map: "idx_screenings_screened_at")
  @@index([createdAt(sort: Desc)], map: "idx_screenings_created_at")
  @@map("screenings")
}

model Surgery {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId              String        @map("patient_id") @db.Uuid
  patientName            String        @map("patient_name")
  campaignId             String        @map("campaign_id") @db.Uuid
  campaignRegionId       String?       @map("campaign_region_id") @db.Uuid
  region                 String        @default("Banadir / Mogadishu")
  operationDistrict      String        @default("Mogadishu") @map("operation_district")
  createdFromScreeningId String?       @map("created_from_screening_id") @db.Uuid
  surgeonName            String?       @map("surgeon_name")
  eye                    SurgeryEye
  lensType               LensType      @map("lens_type")
  scheduledAt            DateTime      @map("scheduled_at") @db.Timestamptz(3)
  performedAt            DateTime?     @map("performed_at") @db.Timestamptz(3)
  status                 SurgeryStatus @default(Scheduled)
  preOpVa                String        @default("") @map("pre_op_va")
  postOpVa               String?       @map("post_op_va")
  complications          String        @default("")
  intraopNotes           String        @default("") @map("intraop_notes")
  completedById          String        @default("") @map("completed_by_id")
  completedByName        String        @default("") @map("completed_by_name")
  createdAt              DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  patient        Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  campaign       Campaign        @relation(fields: [campaignId], references: [id])
  campaignRegion CampaignRegion? @relation(fields: [campaignRegionId], references: [id])
  followUps      FollowUp[]

  @@index([patientId], map: "idx_surgeries_patient_id")
  @@index([campaignId], map: "idx_surgeries_campaign_id")
  @@index([campaignRegionId], map: "idx_surgeries_campaign_region_id")
  @@index([region], map: "idx_surgeries_region")
  @@index([status], map: "idx_surgeries_status")
  @@index([region, status], map: "idx_surgeries_region_status")
  @@index([region, campaignId], map: "idx_surgeries_region_campaign_id")
  @@index([scheduledAt(sort: Desc)], map: "idx_surgeries_scheduled_at")
  @@index([createdAt(sort: Desc)], map: "idx_surgeries_created_at")
  @@map("surgeries")
}

model FollowUp {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId            String             @map("patient_id") @db.Uuid
  patientName          String             @map("patient_name")
  surgeryId            String             @map("surgery_id") @db.Uuid
  campaignId           String             @map("campaign_id") @db.Uuid
  campaignRegionId     String?            @map("campaign_region_id") @db.Uuid
  region               String             @default("Banadir / Mogadishu")
  milestone            FollowUpMilestone
  dueDate              DateTime           @map("due_date") @db.Date
  completedAt          DateTime?          @map("completed_at") @db.Timestamptz(3)
  status               FollowUpStatus     @default(Pending)
  vaRightPost          String?            @map("va_right_post")
  vaLeftPost           String?            @map("va_left_post")
  complications        String             @default("")
  notes                String             @default("")
  needsDoctorReview    Boolean            @default(false) @map("needs_doctor_review")
  doctorReviewStatus   DoctorReviewStatus @default(NotNeeded) @map("doctor_review_status")
  doctorReviewedAt     DateTime?          @map("doctor_reviewed_at") @db.Timestamptz(3)
  doctorName           String             @default("") @map("doctor_name")
  doctorDiagnosis      String             @default("") @map("doctor_diagnosis")
  doctorTreatmentPlan  String             @default("") @map("doctor_treatment_plan")
  doctorNotes          String             @default("") @map("doctor_notes")
  nextAppointmentDate  DateTime?          @map("next_appointment_date") @db.Date
  completedById        String             @default("") @map("completed_by_id")
  completedByName      String             @default("") @map("completed_by_name")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)

  patient        Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  surgery        Surgery          @relation(fields: [surgeryId], references: [id], onDelete: Cascade)
  campaign       Campaign         @relation(fields: [campaignId], references: [id])
  campaignRegion CampaignRegion?  @relation(fields: [campaignRegionId], references: [id])
  medications    FollowUpMedication[]

  @@index([patientId], map: "idx_follow_ups_patient_id")
  @@index([surgeryId], map: "idx_follow_ups_surgery_id")
  @@unique([surgeryId, milestone], map: "follow_ups_surgery_id_milestone_key")
  @@index([surgeryId, milestone], map: "idx_follow_ups_surgery_milestone")
  @@index([campaignId], map: "idx_follow_ups_campaign_id")
  @@index([campaignRegionId], map: "idx_follow_ups_campaign_region_id")
  @@index([region], map: "idx_follow_ups_region")
  @@index([region, status], map: "idx_follow_ups_region_status")
  @@index([region, dueDate], map: "idx_follow_ups_region_due_date")
  @@index([dueDate], map: "idx_follow_ups_due_date")
  @@index([status], map: "idx_follow_ups_status")
  @@index([status, dueDate], map: "idx_follow_ups_status_due_date")
  @@index([needsDoctorReview], map: "idx_follow_ups_needs_doctor_review")
  @@index([doctorReviewStatus], map: "idx_follow_ups_doctor_review_status")
  @@index([createdAt(sort: Desc)], map: "idx_follow_ups_created_at")
  @@map("follow_ups")
}

model FollowUpMedication {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followUpId   String           @map("follow_up_id") @db.Uuid
  drugName     String           @map("drug_name")
  dosage       String           @default("")
  frequency    String           @default("")
  duration     String           @default("")
  instructions String           @default("")
  status       MedicationStatus @default(Prescribed)
  notes        String           @default("")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)

  followUp FollowUp @relation(fields: [followUpId], references: [id], onDelete: Cascade)

  @@index([followUpId], map: "idx_follow_up_medications_follow_up_id")
  @@map("follow_up_medications")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor      String
  actorId    String   @default("") @map("actor_id")
  actorName  String   @default("") @map("actor_name")
  actorRole  String   @default("") @map("actor_role")
  action     String
  entity     String
  entityId   String   @map("entity_id")
  region     String?
  campaignId String?  @map("campaign_id") @db.Uuid
  details    String   @default("")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([entity, entityId], map: "idx_audit_logs_entity")
  @@index([region], map: "idx_audit_logs_region")
  @@index([campaignId], map: "idx_audit_logs_campaign_id")
  @@index([actorId], map: "idx_audit_logs_actor_id")
  @@index([action], map: "idx_audit_logs_action")
  @@index([region, createdAt(sort: Desc)], map: "idx_audit_logs_region_created_at")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}
